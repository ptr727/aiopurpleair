# Live-validation credentials for the PurpleAir API.
#
# Copy this file to .env.test (gitignored) and fill in real values, then run:
#   AIOPURPLEAIR_LIVE_TESTS=1 uv run pytest -m live -q
#
# NEVER commit real keys. .env.test is gitignored; only this .example is tracked.
# See AGENTS.md "Live API validation" for the full process.

# A READ API key (required). Created in the PurpleAir Developer Dashboard.
PURPLEAIR_API_KEY=

# An optional second READ key from a *different* account, exercised alongside
# PURPLEAIR_API_KEY by the live tests to cover different account states (e.g. a
# positive vs an overdrawn points balance). Omit to run with a single key.
PURPLEAIR_API_KEY_2=

# A WRITE key (same account as PURPLEAIR_API_KEY), for the Groups API round-trip
# live test. Without it the groups live test skips.
PURPLEAIR_API_KEY_WRITE=

# The registration email that owns the sensors below. Enables the live groups
# test to add an owned sensor as a member (needed to exercise member reads).
# Without it the groups live test still runs create/list/delete.
PURPLEAIR_OWNER_EMAIL=

# Two owned/private sensors, queried free with their per-sensor read keys.
# PURPLEAIR_SENSOR_INDEX_* is the numeric sensor_index; READ_KEY is the private key.
PURPLEAIR_SENSOR_INDEX_1=
PURPLEAIR_SENSOR_READ_KEY_1=
PURPLEAIR_SENSOR_INDEX_2=
PURPLEAIR_SENSOR_READ_KEY_2=
