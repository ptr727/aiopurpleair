# Default: do not normalize line endings (`* -text`); .editorconfig end_of_line rules guide what the editor
# writes. The exception pin below is git's own enforcement - it forces LF for execution-sensitive scripts
# regardless of editor.
# git config --global core.autocrlf false
# git add --renormalize .
# git ls-files --eol
* -text

# Shell scripts must stay LF regardless of the `* -text` default - a CRLF shebang breaks execution.
*.sh text eol=lf
